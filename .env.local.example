# LinkedIn Marketing API — copy to .env.local (local dev) and set the same in
# Vercel Project Settings → Environment Variables (Production). Never commit real values.

# From your LinkedIn developer app (Auth tab)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Must EXACTLY match an "Authorized redirect URL" in the LinkedIn app:
#   local:  http://localhost:3000/api/linkedin/callback
#   prod:   https://<your-domain>/api/linkedin/callback
LINKEDIN_REDIRECT_URI=

# Versioned REST API (YYYYMM). Optional; defaults to a recent version in code.
LINKEDIN_API_VERSION=202411

# 32+ char random secret used to encrypt the stored OAuth token cookie.
# Generate: openssl rand -base64 32
TOKEN_ENC_KEY=
